  "keyFeatures": [
    "Dual-role authentication (patients and doctors use separate guards)",
    "Appointment scheduling with date/time conflict prevention",
    "Full appointment lifecycle management (scheduled, cancelled, completed)",
    "Role-aware dashboard showing today's appointments",
    "Soft deletes on all core entities (patients, doctors, appointments)",
    "Appointment duration tracking (15–180 minutes)",
    "RESTful resource routes for appointment CRUD"
  ],
  "publicApiSurface": [
    "GET /login — Show login form",
    "POST /login — Authenticate patient or doctor",
    "POST /logout — End session",
    "GET /dashboard — Show today's appointments dashboard",
    "GET /citas — List all appointments for authenticated user",
    "GET /citas/create — Show appointment creation form",
    "POST /citas — Store a new appointment",
    "GET /citas/{id}/edit — Show appointment edit form",
    "PUT /citas/{id} — Update an appointment",
    "PATCH /citas/{id}/cancelar — Cancel an appointment"
  ]
